<!DOCTYPE html> 

<html lang="en"> 

 

<head> 

    <meta charset="UTF-8"> 

    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 

    <title>Login - BrainRoute</title> 

 

    <!-- Fonts --> 

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"> 

 

    <!-- Styles --> 

    <link rel="stylesheet" href="style.css"> 

    <link rel="stylesheet" href="auth.css"> 

</head> 

 

<body> 

 

<div class="auth-layout"> 

 

    <!-- Left Side --> 

    <div class="auth-left"> 

 

        <div class="auth-brand"> 

            <img src="Logo.png" alt="Brain Route Logo"> 

            <span class="auth-brand-name">Brain Route</span> 

        </div> 

        <h2 class="auth-title">Plan Smarter,<br>Study Better.</h2> 

        <p class="auth-desc">Your personalized study planner that adapts to your schedule and deadlines.</p> 

 

        <ul class="auth-features"> 

            <li class="auth-feature"> 

                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"> 

                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/> 

                </svg> 

                Auto-generated weekly study plans 

            </li> 

            <li class="auth-feature"> 

                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"> 

                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/> 

                </svg> 

                Deadline-aware scheduling 

            </li> 

            <li class="auth-feature"> 

                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"> 

                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/> 

                </svg> 

                Progress tracking and smart reminders 

            </li> 

        </ul> 

 

    </div> 

 

    <!-- Right Side --> 

    <div class="auth-right"> 

 

        <h3 class="auth-form-title">Welcome Back!</h3> 

        <p class="auth-form-sub">Sign in to access your study planner</p> 

 

        <!-- Login Form (FR1.3) - email max=100, password max=50 --> 

        <form class="auth-form" method="post" action="#"> 

 

            <div class="form-group"> 

                <label for="email">University Email</label> 

                <div class="input-with-icon"> 

                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"> 

                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/> 

                        <polyline points="22,6 12,13 2,6"/> 

                    </svg> 

                    <input type="email" id="email" name="email" placeholder="student@university.edu" maxlength="100" required> 

                </div> 

            </div> 

 

            <div class="form-group"> 

                <label for="password">Password</label> 

                <div class="input-with-icon"> 

                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"> 

                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/> 

                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/> 

                    </svg> 

                    <input type="password" id="password" name="password" placeholder="••••••••" maxlength="50" required> 

                </div> 

                <a href="#" class="forgot-password">Forgot password?</a> 

            </div> 

 

            <input type="submit" class="button button-primary button-block" value="Log In"> 

 

        </form> 

 

        <p class="auth-switch">Don't have an account? <a href="register.html">Create account →</a></p> 

 

    </div> 

 

</div> 

 

</body> 

</html> 
